{
  "name": "oui-spy-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:types": "openapi-typescript api/openapi.yaml -o src/api/schema.d.ts",
    "dev": "vite",
    "build:vite": "vite build",
    "build:header": "node scripts/generate-header.mjs",
    "build": "npm run generate:types && npm run build:vite && npm run build:header",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@preact/preset-vite": "^2.9.4",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.6.1",
    "tailwindcss": "^4.1.3",
    "terser": "^5.37.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.2",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=22"
  }
}
