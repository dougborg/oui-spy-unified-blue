{
  "name": "oui-spy-unified-blue (USB Linux)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "cacheFrom": "ghcr.io/dougborg/oui-spy-unified-blue/devcontainer:latest"
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "containerEnv": {
    "PLATFORMIO_CORE_DIR": "/home/vscode/.platformio",
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "mounts": [
    "source=pio-home,target=/home/vscode/.platformio,type=volume",
    "source=npm-cache,target=/home/vscode/.npm,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "platformio.platformio-ide",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.vscode-serial-monitor",
        "biomejs.biome",
        "vitest.explorer"
      ],
      "settings": {
        "C_Cpp.default.configurationProvider": "platformio.platformio-ide",
        "files.associations": {
          "*.tcc": "cpp"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && pio --version && pio pkg install -d . && cd web && npm ci && npm run generate:types",
  "postAttachCommand": "echo 'Devcontainer ready. Build with: pio run (see .devcontainer/README.md for USB upload options).'",
  "runArgs": [
    "--init",
    "--privileged",
    "--group-add=dialout",
    "--device=/dev/bus/usb:/dev/bus/usb"
  ]
}
